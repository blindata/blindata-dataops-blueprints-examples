variable "environment" {
  type        = string
  description = "Deployment target (e.g. dev, test, prod). Set by CI/CD when provisioning this stack — not a blueprint instantiation parameter (use TF_VAR_environment, -var, or per-environment tfvars)."
}

variable "domain_slug" {
  type        = string
  description = "Domain identifier for resource naming"
  default     = "$domain_slug"
}

variable "data_owner" {
  type        = string
  description = "Owner identifier for FinOps tagging (blueprint reserved key dpOwnerId)"
  default     = "$dpOwnerId"
}

variable "aws_region" {
  type        = string
  description = "AWS region"
  default     = "eu-west-1"
}

variable "data_retention_days" {
  type        = number
  description = "S3 lifecycle expiration (days) for raw data"
  default     = $data_retention_days
}

variable "enable_pii_masking" {
  type        = bool
  description = "Mirrors blueprint parameter; use for conditional modules if needed"
  default     = #if($enable_pii_masking)true#else false#end
}
